# creoui 公式 site — demo stage 用 Caddy 設定
# SolidJS Router は history mode のため、未知 path は index.html にフォールバックさせる
# (これが無いと /components/button 等を直接 reload した時に 404 になる)。
:80 {
	root * /srv
	encode gzip zstd
	try_files {path} /index.html
	file_server

	# Vite が content hash を付けた assets は長期キャッシュ可
	@hashed path /assets/*
	header @hashed Cache-Control "public, max-age=31536000, immutable"
	# index.html は常に最新を取りに行かせる
	header /index.html Cache-Control "no-cache"
}
