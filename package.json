{
  "name": "@creo/ui",
  "version": "0.0.1",
  "description": "Creo UI - Design System for Creo ecosystem",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "examples/*"],
  "scripts": {
    "build": "bun run build:web && bun run build:swift && bun run build:rust",
    "build:web": "style-dictionary build --config transforms/config.web.js && bun scripts/build-web-components.mjs",
    "build:swift": "style-dictionary build --config transforms/config.swift.js",
    "build:rust": "style-dictionary build --config transforms/config.rust.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check . --write",
    "dev": "cd examples/web-demo && bun install --silent && bun run dev",
    "gen:themes": "bun scripts/generate-themes.mjs",
    "test:colors": "bun test transforms/color-utils.test.js",
    "fetch:design": "bun scripts/fetch-creo-ui-design.mjs",
    "diff:design": "bun scripts/diff-creo-ui-design.mjs"
  },
  "devDependencies": {
    "style-dictionary": "^4.0.0",
    "typescript": "^5.5.0",
    "@biomejs/biome": "^1.9.0"
  }
}
