{
  "editor-mode": {
    "panel": {
      "field-label": {
        "$value": "var(--color-text-secondary)",
        "$type": "color",
        "$description": "Field label の text 色 (active theme の text secondary)"
      },
      "field-value": {
        "$value": "var(--color-text-primary)",
        "$type": "color",
        "$description": "Field value の text 色 (active theme の text primary)"
      },
      "separator": {
        "$value": "var(--color-surface-border-subtle)",
        "$type": "color",
        "$description": "Field group の区切り線 (active theme の border subtle)"
      },
      "field-gap": {
        "$value": "8px",
        "$type": "dimension",
        "$description": "Field 同士の縦間隔"
      },
      "group-gap": {
        "$value": "16px",
        "$type": "dimension",
        "$description": "Field group 間の縦間隔"
      }
    }
  }
}
