    },
    "lg": {
      "$value": "22px",
      "$type": "dimension",
      "$description": "Large radius — modals, larger surfaces"
    },
    "xl": {
      "$value": "28px",
      "$type": "dimension",
      "$description": "Extra-large radius — hero surfaces"
    },
    "full": {
