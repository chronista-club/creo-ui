{
  "name": "creo-ui-frame",
  "version": "0.1.0",
  "description": "Creo UI — 3D Frame system runtime (Spatial Layout protocol + self-built motion engine)。 Frame morph / FLIP / spring / reduced-motion guard を提供。 docs/design/frame-system.md の P-3 reference 実装。",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./motion": {
      "types": "./dist/motion/index.d.ts",
      "import": "./dist/motion/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "repository": {
    "type": "git",
    "url": "https://github.com/chronista-club/creo-ui.git",
    "directory": "packages/frame"
  },
  "bugs": {
    "url": "https://github.com/chronista-club/creo-ui/issues"
  },
  "homepage": "https://github.com/chronista-club/creo-ui#readme",
  "keywords": [
    "creo-ui",
    "frame-system",
    "spatial-ui",
    "3d-layout",
    "motion-engine",
    "flip-animation",
    "spring-physics",
    "solid-js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "bun test src/",
    "typecheck:build": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vite-plugin-solid": "^2.10.0"
  },
  "license": "Apache-2.0"
}
