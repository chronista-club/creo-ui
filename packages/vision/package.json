{
  "name": "creoui-vision",
  "version": "0.1.0",
  "description": "creoui — Webcam motion capture (MediaPipe Tasks wrapper)。 Hand pinch / head pose / face mesh / gesture を Solid signals として expose。 docs/design/vision-input.md の reference 実装。",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js"
    },
    "./mediapipe": {
      "types": "./dist/mediapipe.d.ts",
      "import": "./dist/mediapipe.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "repository": {
    "type": "git",
    "url": "https://github.com/chronista-club/creoui.git",
    "directory": "packages/vision"
  },
  "bugs": {
    "url": "https://github.com/chronista-club/creoui/issues"
  },
  "homepage": "https://github.com/chronista-club/creoui#readme",
  "keywords": [
    "creoui",
    "vision-input",
    "webcam",
    "motion-capture",
    "mediapipe",
    "gesture",
    "spatial-ui",
    "solid-js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "bun test src/",
    "typecheck:build": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0",
    "@mediapipe/tasks-vision": "^0.10.0"
  },
  "peerDependenciesMeta": {
    "@mediapipe/tasks-vision": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mediapipe/tasks-vision": "^0.10.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vite-plugin-solid": "^2.10.0"
  },
  "license": "Apache-2.0"
}
